func open_test_location() {
  load("localhost:3000/admin")
  .location-link[0].wait_visible()
  .location-link[0].click()
  #app-link-candidates.wait_visible()
}

func create_location() {
  #create-location-tab-btn.click()
  #name.fill($test_location_name)
  #number.fill($test_location_number)
  #phone_1.fill("999")
  #phone_2.fill("999")
  #phone_3.fill("9999")
  #employer_rep_signature.fill("John Doe")
  #business_name.fill("MAJOR CFA CORP LLC")
  #business_street.fill(random_address())
  #business_city.fill("Cityville")
  #business_state.select("Oklahoma (OK)")
