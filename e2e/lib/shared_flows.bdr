func process_location_time_punches() {
  switch_back_to_location()
  load($test_location_apps_url)
  #app-link-time-punch.wait_visible()
  #app-link-time-punch.click()
  [data-panel-target="view-punches"].click()
  form[action*="/time-punch/"][action$="/archive"] button[0].wait_visible()

  form[action*="/time-punch/"][action$="/archive"] button[0].click()
  .notice.ok[0].assert_text("Time punch entry marked completed")
}

func process_location_uniform_orders() {
