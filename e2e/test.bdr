func create_candidate() {
  .location-link[0].click()
  #app-link-candidates.click()
  [data-target="new-candidate"].click()
  #first_name.fill(random_username(8))
  #last_name.fill(random_username(10))
  #phone_1.fill("777")
  #phone_2.fill("555")
  #phone_3.fill("1234")
  [data-panel="new-candidate"] button[type="submit"].click()
}

func open_candidate_detail() {
  load("localhost:3000/admin")
  .location-link[0].click()
  #app-link-candidates.click()
  .active-candidate-row[0].click()
}

func create_and_open_interview($interview_type, $scheduled_date, $scheduled_hour, $scheduled_minute, $scheduled_ampm) {
  open_candidate_detail()
  #interviewer_time_punch_name.select("John Doe")
  #scheduled_date.fill($scheduled_date)
  #scheduled_hour.select($scheduled_hour)
  #scheduled_minute.select($scheduled_minute)
  #scheduled_ampm.select($scheduled_ampm)
  #interview_type.select($interview_type)
  [data-panel="view-interviews"] button[type="submit"].click()

  .copy-session-link[0].click()
  load_clipboard()
}

func fill_interview_values() {
  select[id^="grade_"][0].select("A")
  select[id^="grade_"][1].select("A")
  select[id^="grade_"][2].select("B")
  select[id^="grade_"][3].select("A")
  select[id^="grade_"][4].select("B")

  textarea[id^="comment_"][0].fill("Great hospitality and positive energy.")
  textarea[id^="comment_"][1].fill("Takes feedback well and asks good questions.")
  textarea[id^="comment_"][2].fill("Clear communication and respectful tone.")
  textarea[id^="comment_"][3].fill("Showed up early and appears dependable.")
  textarea[id^="comment_"][4].fill("Team-first attitude during scenario questions.")
}

func conduct_phone_interview() {
  create_and_open_interview("Phone Interview", "2030-01-15", "09", "00", "AM")

  #availability-monday-available.click()
  #availability-monday-start.fill("09:00")
  #availability-monday-end.fill("17:00")
  #availability-tuesday-available.click()
  #availability-tuesday-start.fill("09:00")
  #availability-tuesday-end.fill("17:00")
  #availability-wednesday-available.click()
  #availability-wednesday-start.fill("09:00")
  #availability-wednesday-end.fill("17:00")
  #availability-thursday-available.click()
  #availability-thursday-start.fill("09:00")
  #availability-thursday-end.fill("17:00")
  #availability-friday-available.click()
  #availability-friday-start.fill("09:00")
  #availability-friday-end.fill("17:00")
  #availability-saturday-available.click()
  #availability-saturday-start.fill("09:00")
  #availability-saturday-end.fill("17:00")

  fill_interview_values()

  select[id^="question_"][0].select("Yes")
  select[id^="question_"][1].select("Yes")
  select[id^="question_"][2].select("Yes")
  textarea[id^="question_"][0].fill("Candidate wants to grow and serve guests well.")
  textarea[id^="question_"][1].fill("Candidate helped a coworker during a busy shift.")

  #notes.fill("Strong phone interview. Recommend moving to face-to-face.")
  #interview-submit-btn.click()
  h1.assert_text("Interview Submitted")
}

func conduct_face_to_face_interview() {
  create_and_open_interview("Face-to-Face Interview", "2030-01-16", "10", "30", "AM")

  fill_interview_values()

  textarea[id^="question_"][0].fill("Candidate shared a calm, respectful guest recovery example.")
  textarea[id^="question_"][1].fill("Candidate explained prioritizing speed while keeping order accuracy.")
  textarea[id^="question_"][2].fill("Candidate welcomes feedback and applies coaching quickly.")
  textarea[id^="question_"][3].fill("Candidate would step in to support teammates during a rush.")
  textarea[id^="question_"][4].fill("Candidate defines hospitality as serving with care and urgency.")

  #notes.fill("Strong in-person presence and teamwork mindset.")
  #interview-submit-btn.click()
  h1.assert_text("Interview Submitted")
}

func conduct_final_interview() {
  create_and_open_interview("Final Interview", "2030-01-17", "11", "15", "AM")

  fill_interview_values()

  select[id^="question_"][0].select("Yes")
  textarea[id^="question_"][0].fill("Candidate goals include leadership growth and long-term reliability.")
  textarea[id^="question_"][1].fill("Candidate highlighted dependable attendance and strong communication.")
  textarea[id^="question_"][2].fill("Candidate can commit to weekday evenings and Saturdays.")
  textarea[id^="question_"][3].fill("Candidate has no concerns and is excited for team expectations.")

  #notes.fill("Ready to hire based on consistency across all interview stages.")
  #interview-submit-btn.click()
  h1.assert_text("Interview Submitted")
}

func delete_location() {
  load("localhost:3000/admin")
  .location-link[0].click()
  #app-link-settings.click()
  #delete_confirmation.fill("I CHOOSE TO DELETE THIS LOCATION AND ALL OF ITS DATA")
  #delete-location-btn.click()
}

login()
create_location()
create_candidate()
conduct_phone_interview()
conduct_face_to_face_interview()
conduct_final_interview()
delete_location()
